{
  "version": "bronto-tui/v1",
  "name": "implemented-chart-types",
  "title": "Bronto Chart Test (Implemented)",
  "theme": { "brand": "bronto", "density": "comfortable" },
  "defaults": {
    "chartRender": { "mode": "ascii", "showAxis": true },
    "table": { "rowLimit": 200 }
  },
  "layout": {
    "type": "col",
    "id": "root",
    "gap": 1,
    "children": [
      { "type": "header", "id": "hdr", "titleRef": "$title", "subTitle": "bar + line + table" },
      {
        "type": "row",
        "id": "charts_row",
        "gap": 1,
        "weights": [1, 1],
        "children": [
          { "type": "chart", "id": "p_bar", "title": "Errors by Type (Bar)", "chartRef": "errorsBar" },
          { "type": "chart", "id": "p_line", "title": "Latency Trend (Line)", "chartRef": "latencyLine" }
        ]
      },
      {
        "type": "row",
        "id": "table_row",
        "gap": 1,
        "weights": [1, 1],
        "children": [
          { "type": "table", "id": "p_table", "title": "Latest Errors", "tableRef": "latestErrors" },
          { "type": "table", "id": "p_table_warnings", "title": "Latest Warnings", "tableRef": "latestWarnings" }
        ]
      }
    ]
  },
  "charts": {
    "errorsBar": {
      "family": "bar",
      "datasetRef": "errors_by_type",
      "bar": { "orientation": "vertical" }
    },
    "latencyLine": {
      "family": "line",
      "datasetRef": "latency_xy",
      "line": {
        "series": [
          { "name": "p50", "variant": "primary" },
          { "name": "p95", "variant": "danger" }
        ],
        "style": { "interpolation": "linear", "markers": true }
      }
    }
  },
  "tables": {
    "latestErrors": {
      "datasetRef": "latest_errors",
      "columns": [
        { "key": "ts", "title": "ts", "width": "auto" },
        { "key": "service", "title": "service", "width": 14 },
        { "key": "message", "title": "message", "width": "flex" }
      ],
      "rowLimit": 200
    },
    "latestWarnings": {
      "datasetRef": "latest_warnings",
      "columns": [
        { "key": "ts", "title": "ts", "width": "auto" },
        { "key": "service", "title": "service", "width": 14 },
        { "key": "warning", "title": "warning", "width": "flex" }
      ],
      "rowLimit": 200
    }
  },
  "datasets": {
    "errors_by_type": {
      "kind": "categorySeries",
      "unit": "count",
      "labels": ["TimeoutError", "ValidationError", "UpstreamError", "ToolExecutionError", "ModelError"],
      "values": [31, 29, 28, 12, 5]
    },
    "latency_xy": {
      "kind": "xySeries",
      "unit": "ms",
      "xy": [
        {
          "name": "p50",
          "points": [
            { "x": 1, "y": 120 },
            { "x": 2, "y": 132 },
            { "x": 3, "y": 118 },
            { "x": 4, "y": 140 },
            { "x": 5, "y": 127 },
            { "x": 6, "y": 136 }
          ]
        },
        {
          "name": "p95",
          "points": [
            { "x": 1, "y": 210 },
            { "x": 2, "y": 238 },
            { "x": 3, "y": 225 },
            { "x": 4, "y": 260 },
            { "x": 5, "y": 242 },
            { "x": 6, "y": 251 }
          ]
        }
      ]
    },
    "latest_errors": {
      "kind": "table",
      "columns": ["ts", "service", "message"],
      "rows": [
        ["2026-02-22T12:00:01Z", "api", "NullPointerException"],
        ["2026-02-22T12:00:03Z", "worker", "timeout contacting db"],
        ["2026-02-22T12:00:04Z", "web", "500 /checkout"],
        ["2026-02-22T12:00:05Z", "api", "bad request payload"],
        ["2026-02-22T12:00:08Z", "worker", "upstream rate limited"]
      ]
    },
    "latest_warnings": {
      "kind": "table",
      "columns": ["ts", "service", "warning"],
      "rows": [
        ["2026-02-22T12:00:00Z", "gateway", "retrying upstream request"],
        ["2026-02-22T12:00:02Z", "worker", "queue depth over threshold"],
        ["2026-02-22T12:00:06Z", "api", "slow query observed"],
        ["2026-02-22T12:00:07Z", "web", "cache miss spike"],
        ["2026-02-22T12:00:09Z", "gateway", "partial fallback path used"]
      ]
    }
  }
}
