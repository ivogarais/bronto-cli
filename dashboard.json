{
  "version": "1",
  "title": "Errors (Last 30m)",
  "refresh": { "everyMs": 1000 },
  "queries": {
    "q_errors_by_service": { "kind": "bar" },
    "q_latest_errors": { "kind": "table" }
  },
  "widgets": [
    {
      "id": "err_by_service",
      "type": "barchart",
      "title": "Errors by Service",
      "queryRef": "q_errors_by_service"
    },
    {
      "id": "err_rows",
      "type": "table",
      "title": "Latest Error Rows",
      "columns": ["ts", "service", "message"],
      "queryRef": "q_latest_errors"
    }
  ]
}
